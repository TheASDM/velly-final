# ── AI Provider ───────────────────────────────────────────────────────────────
# Which AI backend the chatbot uses.
# Options: anthropic | openwebui
# Default: anthropic
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required when AI_PROVIDER=anthropic
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Which Claude model to use.
# Default: claude-haiku-4-5-20251001
# Other options: claude-sonnet-4-6, claude-opus-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Open WebUI (local) ────────────────────────────────────────────────────────
# Required when AI_PROVIDER=openwebui
# URL of your Open WebUI instance (no trailing slash)
OPENWEBUI_URL=http://YOUR_VM_IP:3000

# API key from Open WebUI → (your avatar) → Settings → Account → API Keys
OPENWEBUI_API_KEY=your_openwebui_key_here

# Which model to use — must be pulled in Ollama on your VM
# Examples: llama3.2, mistral, gemma3, phi4
OPENWEBUI_MODEL=llama3.2

# ── Database ──────────────────────────────────────────────────────────────────
# Only change these if you know what you're doing
POSTGRES_DB=wiki
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=changeme_secure_password
