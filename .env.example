# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Which Claude model to use.
# Default: claude-haiku-4-5-20251001
# Other options: claude-sonnet-4-6, claude-opus-4-6
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Ollama / Embeddings ──────────────────────────────────────────────────────
# URL for Ollama embeddings (include /ollama if behind OpenWebUI proxy)
OLLAMA_URL=https://ai.raptornet.dev/ollama

# Bearer token for Ollama/OpenWebUI authentication
OLLAMA_API_KEY=your_ollama_api_key_here

# ── DM Mode ──────────────────────────────────────────────────────────────────
# Passphrase typed into the chat to unlock DM mode (case-insensitive)
DM_PASSPHRASE=Prima Volta

# ── Embeddings ────────────────────────────────────────────────────────────────
# Must match the model used by build_vectors.py
EMBEDDING_MODEL=nomic-embed-text:latest

# ── Database ──────────────────────────────────────────────────────────────────
# IMPORTANT: Change the password before first deploy
POSTGRES_DB=wiki
POSTGRES_USER=wikijs
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
